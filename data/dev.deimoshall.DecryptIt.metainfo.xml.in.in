<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
    <id>@app-id@</id>

    <name>Decrypt It</name>
    <developer id="dev.deimoshall">
        <name translate="no">Deimos Hall</name>
    </developer>
    <summary>Decrypt DLC files</summary>

    <metadata_license>CC-BY-SA-4.0</metadata_license>
    <project_license>GPL-3.0-only</project_license>

    <description>
        <p>
            Decrypt It allows you to decrypt your DLC files.
        </p>
    </description>

    <categories>
        <category>Utility</category>
        <category>FileTools</category>
        <category>Network</category>
    </categories>

    <keywords>
        <keyword>decrypt</keyword>
        <keyword>dlc</keyword>
        <keyword>jdownloader</keyword>
    </keywords>

    <translation type="gettext">@gettext-package@</translation>

    <requires>
        <display_length compare="ge">360</display_length>
        <internet>always</internet>
    </requires>

    <branding>
        <color type="primary" scheme_preference="light">#f18e57</color>
        <color type="primary" scheme_preference="dark">#29426B</color>
    </branding>

    <screenshots>
        <screenshot>
            <image>
                https://raw.githubusercontent.com/DeimosHall/DecryptIt/dev/data/resources/screenshots/0.png</image>
            <caption>DLC file decrypted</caption>
        </screenshot>
        <screenshot>
            <image>
                https://raw.githubusercontent.com/DeimosHall/DecryptIt/dev/data/resources/screenshots/1.png</image>
            <caption>Error decrypting</caption>
        </screenshot>
        <screenshot type="default">
            <image>
                https://raw.githubusercontent.com/DeimosHall/DecryptIt/dev/data/resources/screenshots/2.png</image>
            <caption>Drag and drop window</caption>
        </screenshot>
    </screenshots>

    <launchable type="desktop-id">@app-id@.desktop</launchable>

    <url type="homepage">https://github.com/DeimosHall/decrypt-it</url>
    <url type="donation">https://ko-fi.com/deimoshall</url>
    <url type="bugtracker">https://github.com/DeimosHall/decrypt-it/issues</url>
    <url type="help">https://github.com/DeimosHall/decrypt-it/issues</url>
    <url type="vcs-browser">https://github.com/DeimosHall/decrypt-it</url>
    <url type="translate">https://github.com/DeimosHall/decrypt-it/tree/main/po</url>
    <url type="contribute">https://github.com/DeimosHall/decrypt-it</url>
    <url type="contact">https://matrix.to/#/@deimoshall:matrix.org</url>

    <update_contact>deimoshall.dev@proton.me</update_contact>

    <content_rating type="oars-1.1" />

    <releases>
        <release version="0.1.0" date="2026-06-24">
            <description>
                <p>First version released</p>
                <ul>
                    <li>Choose DLC files</li>
                    <li>View password and URLs</li>
                </ul>
            </description>
        </release>
    </releases>

</component>
