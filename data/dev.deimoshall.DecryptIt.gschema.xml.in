<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="decrypt-it">
	<enum id="dev.deimoshall.DecryptIt.output">
		<value nick="Png" value="0"/>
		<value nick="Jpg" value="1"/>
		<value nick="Webp" value="2"/>
		<value nick="Heif" value="3"/>
		<value nick="Heic" value="4"/>
		<value nick="Bmp" value="5"/>
		<value nick="Avif" value="6"/>
		<value nick="Jxl" value="7"/>
		<value nick="Tiff" value="8"/>
		<value nick="Pdf" value="9"/>
		<value nick="Gif" value="10"/>
	</enum>
	<enum id="dev.deimoshall.DecryptIt.compression">
		<value nick="Zip" value="0"/>
		<value nick="Dir" value="1"/>
	</enum>

	<schema id="@app-id@" path="/dev/deimoshall/DecryptIt/" gettext-domain="@gettext-package@">
		<key name="window-width" type="i">
			<default>750</default>
			<summary>Window width</summary>
		</key>
		<key name="quality" type="i">
			<default>92</default>
			<summary>Image quality</summary>
		</key>
		<key name="dpi" type="i">
			<default>300</default>
			<summary>Image density per inch</summary>
		</key>
		<key name="window-height" type="i">
			<default>750</default>
			<summary>Window height</summary>
		</key>
			<key name="is-maximized" type="b">
			<default>false</default>
			<summary>Window maximized state</summary>
		</key>
		<key name="output-format" enum="dev.deimoshall.DecryptIt.output">
			<default>'Jpg'</default>
			<summary>Output format</summary>
		</key>
		<key name="compression-format" enum="dev.deimoshall.DecryptIt.compression">
			<default>'Dir'</default>
			<summary>Compression format</summary>
		</key>
	</schema>
</schemalist>
